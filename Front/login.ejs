<%- include('partials/header', { usuario: null }) %>

<style>
  .login-wrapper { display: flex; align-items: center; justify-content: center; min-height: calc(100vh - 100px); }
  .login-card { background: #1a1a2e; border: 1px solid #7c3aed; border-radius: 12px; padding: 2.5rem; width: 100%; max-width: 400px; }
  .login-card h2 { color: #a78bfa; margin-bottom: 1.5rem; text-align: center; }
  .form-group { margin-bottom: 1.25rem; }
  label { display: block; margin-bottom: 0.4rem; font-size: 0.9rem; color: #c4b5fd; }
  input { width: 100%; padding: 0.75rem; border-radius: 8px; border: 1px solid #4c1d95; background: #0f0f1a; color: #e0e0e0; font-size: 1rem; }
  input:focus { outline: none; border-color: #7c3aed; }
  .btn { width: 100%; padding: 0.85rem; border: none; border-radius: 8px; font-size: 1rem; cursor: pointer; margin-top: 0.5rem; }
  .btn-primary { background: #7c3aed; color: white; }
  .btn-primary:hover { background: #6d28d9; }
  .btn-quick { background: #374151; color: #d1d5db; margin-top: 0.75rem; font-size: 0.85rem; }
  .btn-quick:hover { background: #4b5563; }
  .error { background: #450a0a; color: #fca5a5; padding: 0.75rem; border-radius: 8px; margin-bottom: 1rem; font-size: 0.9rem; }
</style>

<div class="login-wrapper">
  <div class="login-card">
    <h2>🔐 Iniciar sesión</h2>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/login">
      <div class="form-group">
        <label for="email">Correo electrónico</label>
        <input type="email" id="email" name="email" required placeholder="admin@gamezone.com">
      </div>
      <div class="form-group">
        <label for="password">Contraseña</label>
        <input type="password" id="password" name="password" required placeholder="••••••••">
      </div>
      <button type="submit" class="btn btn-primary">Ingresar</button>
      <button type="button" class="btn btn-quick" onclick="accesoRapido()">⚡ Acceso rápido (testers)</button>
    </form>
  </div>
</div>

<script>
  function accesoRapido() {
    document.getElementById('email').value = 'admin@gamezone.com';
    document.getElementById('password').value = 'admin123';
  }
</script>
</body>
</html>
