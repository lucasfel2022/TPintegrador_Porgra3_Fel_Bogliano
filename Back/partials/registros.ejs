<%- include('header', { usuario }) %>

<style>
  h2 { color: #a78bfa; margin-bottom: 1.5rem; }
  .btn { padding: 0.6rem 1.2rem; border: none; border-radius: 8px; cursor: pointer; font-size: 0.9rem; text-decoration: none; display: inline-block; }
  .btn-primary { background: #7c3aed; color: white; }
  .btn-secondary { background: #374151; color: #e0e0e0; }
  .admin-container { max-width: 1100px; margin: 2rem auto; padding: 0 1rem; }
  .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
  .admin-actions { display: flex; gap: 0.75rem; }
  .registro-seccion { margin-bottom: 2.5rem; }
  .registro-seccion h3 { color: #c4b5fd; font-size: 1.1rem; border-bottom: 1px solid #4c1d95; padding-bottom: 0.5rem; margin-bottom: 1rem; }
  .tabla-registros { width: 100%; border-collapse: collapse; background: #1a1a2e; border-radius: 10px; overflow: hidden; }
  .tabla-registros th { background: #4c1d95; color: #e9d5ff; padding: 0.75rem 1rem; text-align: left; font-size: 0.85rem; }
  .tabla-registros td { padding: 0.75rem 1rem; border-bottom: 1px solid #2d2d4e; font-size: 0.9rem; }
  .tabla-registros tr:last-child td { border-bottom: none; }
  .tabla-registros tbody tr:hover { background: #16213e; }
</style>

<div class="admin-container">
  <div class="admin-header">
    <h2>📊 Registros</h2>
    <div class="admin-actions">
      <a href="/admin/dashboard" class="btn btn-secondary">← Volver al dashboard</a>
      <a href="/admin/registros/excel" class="btn btn-primary">⬇ Descargar Excel</a>
    </div>
  </div>

  <!-- Top 10 productos más vendidos -->
  <section class="registro-seccion">
    <h3>🏆 Top 10 productos más vendidos</h3>
    <table class="tabla-registros">
      <thead>
        <tr>
          <th>#</th>
          <th>Producto</th>
          <th>Categoría</th>
          <th>Unidades vendidas</th>
        </tr>
      </thead>
      <tbody>
        <% topProductos.forEach((item, i) => { %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= item.Producto ? item.Producto.nombre : 'N/A' %></td>
          <td><%= item.Producto ? item.Producto.categoria : 'N/A' %></td>
          <td><%= item.dataValues.total_vendido %></td>
        </tr>
        <% }) %>
        <% if (topProductos.length === 0) { %>
        <tr><td colspan="4">No hay datos aún</td></tr>
        <% } %>
      </tbody>
    </table>
  </section>

  <!-- Top 10 ventas más caras -->
  <section class="registro-seccion">
    <h3>💰 Top 10 ventas más caras</h3>
    <table class="tabla-registros">
      <thead>
        <tr>
          <th>#</th>
          <th>Cliente</th>
          <th>Total</th>
          <th>Fecha</th>
        </tr>
      </thead>
      <tbody>
        <% topVentas.forEach((venta, i) => { %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= venta.nombre_cliente %></td>
          <td>$<%= Number(venta.precio_total).toLocaleString('es-AR') %></td>
          <td><%= new Date(venta.fecha).toLocaleString('es-AR') %></td>
        </tr>
        <% }) %>
        <% if (topVentas.length === 0) { %>
        <tr><td colspan="4">No hay ventas aún</td></tr>
        <% } %>
      </tbody>
    </table>
  </section>

  <!-- LOG de inicios de sesión -->
  <section class="registro-seccion">
    <h3>🔐 LOG de inicios de sesión</h3>
    <table class="tabla-registros">
      <thead>
        <tr>
          <th>#</th>
          <th>Email</th>
          <th>Fecha</th>
        </tr>
      </thead>
      <tbody>
        <% logs.forEach((log, i) => { %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= log.email %></td>
          <td><%= new Date(log.fecha).toLocaleString('es-AR') %></td>
        </tr>
        <% }) %>
        <% if (logs.length === 0) { %>
        <tr><td colspan="3">No hay registros aún</td></tr>
        <% } %>
      </tbody>
    </table>
  </section>
</div>

<%- include('footer') %>
