<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GameZone Admin</title>
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
  <link rel="stylesheet" href="/style.css">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #0f0f1a; color: #e0e0e0; min-height: 100vh; }
    nav { background: #1a1a2e; padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 2px solid #7c3aed; }
    .nav-brand { display: flex; align-items: center; gap: 0.75rem; }
    .nav-brand h1 { font-size: 1.4rem; color: #a78bfa; }
    .nav-brand span { font-size: 0.75rem; color: #6b7280; display: block; }
    nav a { color: #c4b5fd; text-decoration: none; margin-left: 1.5rem; font-size: 0.9rem; }
    nav a:hover { color: #fff; }
    .btn-tienda { background: #7c3aed; color: #fff !important; padding: 0.4rem 1rem; border-radius: 6px; margin-left: 1.5rem; font-size: 0.9rem; }
    .btn-tienda:hover { background: #6d28d9; }
    .container { max-width: 1100px; margin: 2rem auto; padding: 0 1rem; }
    .alumnos { font-size: 0.7rem; color: #6b7280; text-align: right; padding: 0.25rem 2rem; background: #1a1a2e; }
  </style>
</head>
<body>
<div class="alumnos">Alumnos: Lucas Fel &amp; Milagros Bogliano — UTN Avellaneda</div>
<nav>
  <div class="nav-brand">
    <div>🎮</div>
    <div>
      <h1>GameZone</h1>
      <span>Panel de Administración</span>
    </div>
  </div>
  <div>
    <% if (typeof usuario !== 'undefined' && usuario) { %>
      <a href="/admin/dashboard">Dashboard</a>
      <a href="/admin/registros">Registros</a>
      <a href="/admin/asistencia">Asistencia</a>
      <a href="/admin/logout">Cerrar sesión</a>
    <% } %>
    <a href="/" class="btn-tienda">🛒 Ir a la tienda</a>
  </div>
</nav>
