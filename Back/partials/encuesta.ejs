<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GameZone — Encuesta de satisfacción</title>
  <link rel="icon" href="/img/favicon.png" type="image/png">
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <div class="alumnos-bar">Alumnos: Lucas Fel &amp; Milagros Bogliano — UTN Avellaneda</div>

  <nav class="navbar">
    <div class="navbar-brand">
      <span class="logo">🎮</span>
      <h1>GameZone</h1>
    </div>
    <div class="navbar-links">
      <button id="btn-tema" class="btn-tema" title="Cambiar tema">🌙</button>
    </div>
  </nav>

  <main class="container">
    <div class="encuesta-wrapper">
      <h2>Contanos qué te pareció</h2>
      <p class="encuesta-intro">Tu opinión nos ayuda a mejorar. Te toma menos de un minuto.</p>

      <form id="form-encuesta" novalidate>
        <input type="hidden" id="venta_id" name="venta_id" value="<%= ventaId || '' %>">

        <!-- TEXTAREA -->
        <div class="campo-form">
          <label for="opinion">Contanos tu experiencia</label>
          <textarea id="opinion" name="opinion" rows="4" placeholder="¿Qué te pareció la compra?"></textarea>
          <span class="error-campo" id="error-opinion"></span>
        </div>

        <!-- EMAIL -->
        <div class="campo-form">
          <label for="email">Tu email</label>
          <input type="email" id="email" name="email" placeholder="nombre@email.com">
          <span class="error-campo" id="error-email"></span>
        </div>

        <!-- SLIDER -->
        <div class="campo-form">
          <label for="puntuacion">¿Qué puntaje le darías al servicio? <strong id="valor-puntuacion">5</strong>/10</label>
          <input type="range" id="puntuacion" name="puntuacion" min="1" max="10" value="5">
          <span class="error-campo" id="error-puntuacion"></span>
        </div>

        <!-- FILE -->
        <div class="campo-form">
          <label for="imagen">Subí una foto (opcional)</label>
          <input type="file" id="imagen" name="imagen" accept="image/png, image/jpeg, image/webp">
          <span class="error-campo" id="error-imagen"></span>
        </div>

        <!-- CHECKBOX -->
        <div class="campo-form campo-checkbox">
          <label class="label-checkbox">
            <input type="checkbox" id="acepta_contacto" name="acepta_contacto">
            Acepto que GameZone me contacte por este medio si es necesario
          </label>
        </div>

        <div class="encuesta-acciones">
          <button type="submit" class="btn btn-primary">Enviar encuesta</button>
          <button type="button" id="btn-omitir" class="btn-omitir">Omitir</button>
        </div>

        <p class="error-general" id="error-general"></p>
      </form>
    </div>
  </main>

  <!-- MODAL DE AGRADECIMIENTO -->
  <div id="modal-gracias" class="modal-overlay">
    <div class="modal">
      <h3>¡Gracias por tu opinión! 🎮</h3>
      <p>Tu encuesta fue registrada correctamente.</p>
      <div class="modal-btns">
        <button id="btn-cerrar-gracias" class="btn btn-primary">Volver al inicio</button>
      </div>
    </div>
  </div>

  <footer>GameZone © 2026 — Trabajo Integrador Programación III</footer>

  <script src="/app.js"></script>
  <script src="/encuesta.js"></script>
</body>
</html>
